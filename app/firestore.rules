rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: is the requester a registered admin? ──
    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ── Admin registry ──
    // Only existing admins can read/write the admins collection
    match /admins/{adminId} {
      allow read, write: if isAdmin();
    }

    // ── User cards ──
    match /users/{uid}/cards/{cardId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read, write: if isAdmin();
    }

    // ── Collection group access for admin panel ──
    // Allows collectionGroup('cards') queries across all user subcollections
    match /{path=**}/cards/{cardId} {
      allow read, write: if isAdmin();
    }

    // ── User settings ──
    match /users/{uid}/settings/{settingId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read, write: if isAdmin();
    }

    // ── User profile docs ──
    // Users can read/write their own profile doc (reward credits, streaks, AI session, etc.)
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read, write: if isAdmin();

      // ── Phase 2: Referral milestone reward ──────────────────────────────────
      // Allow an invitee to award card_credits and increment referral_count on
      // their referrer's document when they upload their 10th card.
      // Guards:
      //   1. Requester must be a different user (not self-referral)
      //   2. Invitee's own doc must have referral_source pointing to this uid
      //   3. Referral must not have been rewarded yet (prevents double-payment)
      //   4. Only card_credits and referral_count may be modified
      allow update: if request.auth != null
        && request.auth.uid != uid
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.referral_source == uid
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.referral_rewarded != true
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['card_credits', 'referral_count']);
    }

    // ── Public blog articles ──
    match /articles/{articleId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Push notifications (written by admin panel, read by the app) ──
    match /notifications/{notifId} {
      allow read: if request.auth != null;
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

  }
}
