# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# eBay Browse API credentials (client credentials grant — used for price lookups)
VITE_EBAY_CLIENT_ID=
VITE_EBAY_CLIENT_SECRET=

# eBay Sell API — RuName from eBay Developer Portal (used for OAuth authorization code flow)
# Register redirect URI: https://app.myvaults.io/ebay-callback.html in your eBay app settings
VITE_EBAY_RU_NAME=

# Firebase — values from Firebase console → Project Settings → Your apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
